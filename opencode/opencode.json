{
  "$schema": "https://opencode.ai/config.json",

  "model": "dashscope/glm-5",
  "small_model": "dashscope/qwen3-coder-next",

  "provider": {
    "dashscope": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DashScope",
      "options": {
        "baseURL": "{env:DASHSCOPE_BASE_URL}",
        "apiKey": "{env:DASHSCOPE_API_KEY}"
      },
      "models": {
        "qwen3.5-plus": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        },
        "kimi-k2.5": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        },
        "MiniMax-M2.5": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        },
        "glm-5": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        },
        "glm-4.7": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        },
        "qwen3-coder-next": {
          "tools": true,
          "options": {
            "maxTokens": 65536
          }
        }
      }
    },
    "gemini": {
      "npm": "@ai-sdk/google-generative-ai",
      "name": "Google Gemini",
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": {},
        "gemini-2.5-pro": {}
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "gemma3:4b": {},
        "qwen2.5vl:3b": {}
      }
    }
  }
}
