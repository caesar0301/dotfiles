{
  "LOG": true,
  "LOG_LEVEL": "info",
  "CLAUDE_PATH": "",
  "HOST": "127.0.0.1",
  "PORT": 53456,
  "APIKEY": "your-api-secret",
  "API_TIMEOUT_MS": "600000",
  "PROXY_URL": "",
  "transformers": [],
  "Providers": [
    {
      "name": "dashscope",
      "api_base_url": "${DASHSCOPE_BASE_URL}/chat/completions",
      "api_key": "${DASHSCOPE_API_KEY}",
      "models": [
        "qwen3.6-flash",
        "qwen3.6-plus",
        "qwen3.7-plus",
        "glm-5",
        "glm-5.2",
        "kimi-k2.5",
        "MiniMax-M2.5",
        "text-embedding-v4"
      ],
      "transformer": {
        "use": [["maxtoken", { "max_tokens": 65536 }]]
      }
    },
    {
      "name": "ollama",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "ollama",
      "models": ["gemma3:4b", "qwen2.5vl:3b"]
    }
  ],
  "StatusLine": {
    "enabled": true,
    "currentStyle": "default",
    "default": {
      "modules": [
        {
          "type": "model",
          "icon": "🤖",
          "text": "{{model}}",
          "color": "bright_cyan"
        }
      ]
    },
    "powerline": {
      "modules": []
    }
  },
  "Router": {
    "default": "dashscope,glm-5",
    "think": "dashscope,glm-5",
    "image": "dashscope,qwen3.7-plus"
  },
  "CUSTOM_ROUTER_PATH": ""
}
